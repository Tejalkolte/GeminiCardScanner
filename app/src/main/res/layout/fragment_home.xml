<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#0F1117">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📇"
        android:textSize="72sp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Card Scanner AI"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨ Powered by Gemini AI"
        android:textSize="13sp"
        android:textColor="#00E676"
        android:gravity="center"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Free · 1500 scans/day · No credit card"
        android:textSize="12sp"
        android:textColor="#5a6890"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCamera"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📷  Take a Photo"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#4A90FF"
        app:cornerRadius="14dp"
        android:layout_marginBottom="14dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnGallery"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🖼  Choose from Gallery"
        android:textSize="16sp"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        app:strokeColor="#4A90FF"
        app:strokeWidth="2dp"
        android:textColor="#4A90FF"
        app:cornerRadius="14dp"/>

</LinearLayout>
